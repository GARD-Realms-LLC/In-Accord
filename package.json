{
  "name": "In-Accord",
  "version": "1.0.204",
  "inaccordDisplayVersion": "1.0.29",
  "main": "electron/main.cjs",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/GARD-Realms-LLC/In-Accord"
  },
  "homepage": "https://github.com/GARD-Realms-LLC/In-Accord",
  "bugs": {
    "url": "https://github.com/GARD-Realms-LLC/In-Accord/issues"
  },
  "scripts": {
    "clean:next": "node -e \"const fs=require('fs');for(const p of [process.env.NEXT_DIST_DIR||'.next','.next/dev/types','.next-dev/dev/types'])fs.rmSync(p,{recursive:true,force:true})\"",
    "clean:next:all": "node -e \"const fs=require('fs');for(const p of ['.next-dev','.next'])fs.rmSync(p,{recursive:true,force:true})\"",
    "cleanup:caches": "node scripts/cleanup-caches.cjs",
    "cleanup:caches:dry": "node scripts/cleanup-caches.cjs --dry-run",
    "cleanup:caches:deep": "node scripts/cleanup-caches.cjs --include-win64",
    "dev": "set NEXT_DIST_DIR=.next-dev&& next dev --webpack -p 3000",
    "dev:3000": "set NEXT_DIST_DIR=.next&& npm run clean:next && next dev --webpack -p 3000",
    "cleanup:dist-locks": "node scripts/cleanup-dist-locks.cjs",
    "prepare:win-fav-icon": "node scripts/prepare-win-fav-icon.cjs",
    "generate:win-icon": "node scripts/generate-windows-icon.cjs",
    "version:bump:patch": "node scripts/bump-version.cjs",
    "build": "npm run cleanup:dist-locks && npm run clean:next && next build --webpack",
    "build:dev:portable": "set \"BUILD_OUTPUT_DIR=dist\\Win Dev\"&& npm run cleanup:dist-locks && npm run clean:next && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "electron:wait": "wait-on tcp:3000",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron:wait && npm run electron\"",
    "electron:start": "concurrently -k \"npm run start\" \"npm run electron:wait && npm run electron\"",
    "preelectron:dist": "set BUILD_OUTPUT_DIR=dist\\win64&& npm run cleanup:dist-locks && npm run prepare:win-fav-icon",
    "preelectron:pack": "set BUILD_OUTPUT_DIR=dist\\win64&& npm run cleanup:dist-locks && npm run prepare:win-fav-icon",
    "preelectron:pack:dev": "set \"BUILD_OUTPUT_DIR=dist\\Win Dev\"&& npm run cleanup:dist-locks && npm run prepare:win-fav-icon",
    "electron:pack": "npm run build && npm run prepare:win-fav-icon && node -e \"require('fs').mkdirSync('.electron-cache/tmp',{recursive:true})\" && set ELECTRON_CACHE=.electron-cache\\electron&& set ELECTRON_BUILDER_CACHE=.electron-cache\\builder&& set TEMP=%CD%\\.electron-cache\\tmp&& set TMP=%CD%\\.electron-cache\\tmp&& set BUILD_OUTPUT_DIR=dist\\win64&& electron-builder --dir --win --x64 -c.directories.output=dist/win64 -c.win.signAndEditExecutable=false",
    "electron:pack:dev": "node scripts/pack-win-dev-guarded.cjs",
    "electron:dist": "npm run build:release:strict",
    "electron:dist:unblocked": "npm run build:release:strict",
    "build:release:strict": "node scripts/build-release-strict.cjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:replace-discord-live": "node scripts/replace-discord-live-db.cjs",
    "db:replace-discord-live:fallback": "node scripts/replace-discord-live-db.cjs --allow-fallback",
    "db:replace-discord-live:dry": "node scripts/replace-discord-live-db.cjs --dry-run",
    "db:replace-discord-live:dry:fallback": "node scripts/replace-discord-live-db.cjs --dry-run --allow-fallback",
    "db:replace-discord-db:dry": "node scripts/replace-discord-live-db.cjs --use-database-url --dry-run",
    "db:cleanup:legacy-role-groups:dry": "node scripts/cleanup-legacy-role-channel-groups.cjs --use-database-url",
    "db:cleanup:legacy-role-groups": "node scripts/cleanup-legacy-role-channel-groups.cjs --use-database-url --apply",
    "db:backfill:stage:dry": "node scripts/backfill-stage-channels.cjs --use-database-url",
    "db:backfill:stage": "node scripts/backfill-stage-channels.cjs --use-database-url --apply",
    "db:remove:stage-groups:dry": "node scripts/remove-stage-channel-groups.cjs --use-database-url",
    "db:remove:stage-groups": "node scripts/remove-stage-channel-groups.cjs --use-database-url --apply",
    "db:backfill:ungroup-audio-video:dry": "node scripts/backfill-ungroup-audio-video-channels.cjs --use-database-url",
    "db:backfill:ungroup-audio-video": "node scripts/backfill-ungroup-audio-video-channels.cjs --use-database-url --apply",
    "bot:template-me:inspect": "node scripts/inspect-bot-ciphers.cjs",
    "bot:template-me:smoke": "node scripts/smoke-template-me-control-port.cjs",
    "bot:template-me:live": "node scripts/template-me-live-terminal.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@hookform/resolvers": "3.9.0",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@stripe/react-stripe-js": "^3.9.0",
    "@stripe/stripe-js": "^7.9.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "20.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uploadthing/react": "^7.3.3",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "class-variance-authority": "0.7.1-canary.2",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "discord.js": "^14.25.1",
    "drizzle-orm": "^0.44.5",
    "eslint-config-next": "^16.1.6",
    "lucide-react": "0.438.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "query-string": "9.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "14.2.3",
    "react-hook-form": "7.53.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "2.5.2-dev.a9aa5911cc624d0ddd2ee81bcce00b932a437aea",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "1.0.7",
    "typescript": "5.2.2",
    "uploadthing": "^7.7.4",
    "uuid": "10.0.0",
    "zlib-sync": "^0.1.10",
    "zod": "3.24.0-canary.20240701T200529",
    "zustand": "5.0.0-rc.1"
  },
  "devDependencies": {
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "10.0.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.5",
    "electron": "35.7.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.0",
    "png-to-ico": "^3.0.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.gardrealms.inaccord",
    "productName": "In-Accord",
    "icon": "dist/win64/fav.ico",
    "artifactName": "In-Accord-Setup-v${version}-${arch}.${ext}",
    "afterPack": "scripts/electron-after-pack-copy-next-external-aliases.cjs",
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "files": [
      "electron/**/*",
      "Images/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json",
      "next.config.js",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist/win64"
    },
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": ".data",
        "to": ".data"
      }
    ],
    "win": {
      "icon": "dist/win64/fav.ico",
      "executableName": "In-Accord",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "guid": "5a0f84d4-5250-4b4f-a071-c2031f6f6936",
      "oneClick": false,
      "runAfterFinish": false,
      "buildUniversalInstaller": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "In-Accord",
      "installerIcon": "dist/win64/fav.ico"
    }
  }
}
