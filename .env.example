# Core
DATABASE_URL=mysql://user:password@localhost:3306/in_accord
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret

# UploadThing
UPLOADTHING_TOKEN=replace-with-your-uploadthing-token
UPLOADTHING_SECRET=replace-with-your-uploadthing-secret
UPLOADTHING_APP_ID=replace-with-your-uploadthing-app-id

# Optional security
BOT_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Optional desktop/electron
ELECTRON_START_URL=http://localhost:3000
INACCORD_UPDATE_MANIFEST_URL=
INACCORD_UPDATE_CHECK_INTERVAL_MS=60000

# External account connections (Settings > Connections)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
XBOX_CLIENT_ID=
XBOX_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Slash command limits (defaults shown)
# Non In-Accord bots/apps default to 100
SLASH_COMMAND_LIMIT_NON_IN_ACCORD=100
# In-Accord bots/apps default to 200
SLASH_COMMAND_LIMIT_IN_ACCORD=200
